# Kopyala: .env.example -> .env  (gerçek .env asla commit edilmez)

# --- PostgreSQL (01_System_Architecture.md §2) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=berber_saas
# Standart uygulama rolü — RLS bu rol için de zorunlu (FORCE ROW LEVEL SECURITY).
DB_APP_USER=berber_app
DB_APP_PASSWORD=change_me
# Servis rolü — BYPASSRLS. Yalnızca: login (tenant henüz bilinmiyor), /internal/resolve-tenant,
# n8n'in tüm-tenant tarama endpoint'leri (04§5/§6), platform admin panel (09§5) için kullanılır.
# Bkz. migrations/0000_roles.example.sql
DB_SERVICE_USER=berber_service
DB_SERVICE_PASSWORD=change_me

# --- Auth (03_Backend_API.md §2) ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_TTL_SECONDS=7200
N8N_SERVICE_SECRET=change_me_shared_hmac_secret
# n8n'de "Gelen Mesaj" workflow'unun Webhook node URL'i (04_n8n_Workflows.md §1) — boşsa Backend
# gelen mesajı n8n'e iletmeden sessizce atlar.
N8N_INCOMING_WEBHOOK_URL=

# --- Meta Cloud API (01§4, 05_WhatsApp_Integration.md) ---
# Embedded Signup (05§1): panel FB.init için App ID + Facebook Login for Business config ID.
# Config ID, Meta Dashboard > Facebook Login for Business > Configurations'tan oluşturulur;
# boşsa panel "Yeniden Bağlan" butonu yapılandırma uyarısı gösterir.
META_APP_ID=
META_ES_CONFIG_ID=
META_APP_SECRET=
WEBHOOK_VERIFY_TOKEN=
# tenants.access_token_encrypted için AES-256-GCM anahtarı (base64, 32 byte). KMS kapsam dışı (05§1).
APP_ENCRYPTION_KEY=

# WhatsApp Flows (randevu formu, PHASE_35): RSA private key dosya yolu (public key Meta'ya
# yüklendi) + Meta'da oluşturulan Flow'un ID'si. secrets/*.pem asla commit edilmez (.gitignore).
WHATSAPP_FLOW_PRIVATE_KEY_PATH=
META_FLOW_ID=

# --- AI (07_AI_Module.md §4) ---
# Sağlayıcı önceliği: GEMINI_API_KEY doluysa Gemini (ücretsiz katman) kullanılır, aksi halde
# ANTHROPIC_API_KEY. İkisi de boşsa AI fallback şablonuna düşer (LLM çağrısı yapılmaz).
GEMINI_API_KEY=
# Opsiyonel; boşsa gemini-2.5-flash. Ör: gemini-2.0-flash (daha geniş ücretsiz kota).
GEMINI_MODEL=
ANTHROPIC_API_KEY=

# --- Redis (rate limit sayaçları, 07§5 — BACKLOG §A m.11/16; boşsa 127.0.0.1:6379 varsayılır) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
